# Wenjuan requires a generic Postgres-compatible SQL database in every environment.
# Put real credentials in .env.local or deployment env, never in git.
DATABASE_URL=postgresql://USER:<PASSWORD>@HOST:6543/postgres?sslmode=require

# OpenAI-compatible AI endpoints (server-side only; keep real keys in .env.local / deployment env)
# Multi-model config supports one endpoint with multiple models, or multiple endpoints.
# WENJUAN_AI_PROVIDERS_JSON='[{"id":"primary","alias":"主服务","baseUrl":"http://localhost:4000/v1","apiKey":"<replace-with-key>","models":[{"id":"mimo-v2.5","alias":"主模型","primary":true},{"id":"qwen2.5","alias":"备用模型"}]},{"id":"backup","alias":"备用服务","baseUrl":"http://localhost:4010/v1","apiKey":"<replace-with-key>","models":[{"id":"backup-model","alias":"远端备用"}]}]'
#
# Legacy single-model config is still accepted.
# WENJUAN_AI_BASE_URL=http://localhost:4000/v1
# WENJUAN_AI_API_KEY=<replace-with-local-key>
# WENJUAN_AI_MODEL=mimo-v2.5
# WENJUAN_AI_MODEL_ALIAS=Mimo v2.5
# WENJUAN_AI_PROVIDER_ALIAS=本地服务

# Public demo deployment controls. Keep disabled for normal private/local usage unless you are running the demo site.
WENJUAN_DEMO_MODE=false
# WENJUAN_DEMO_VISITOR_SECRET=replace-with-long-random-secret
# WENJUAN_DEMO_IP_HASH_SECRET=replace-with-another-long-random-secret
# WENJUAN_DEMO_MAX_SURVEYS_PER_VISITOR=5
# WENJUAN_DEMO_MAX_RESPONSES_PER_SURVEY=50
# WENJUAN_DEMO_AI_DAILY_LIMIT_PER_IP=10
# WENJUAN_DEMO_SUBMIT_HOURLY_LIMIT_PER_IP=20
# WENJUAN_DEMO_DATA_TTL_DAYS=7
# WENJUAN_DEMO_DB_USAGE_CLEANUP_THRESHOLD=0.9
# Optional: set this to your demo database quota in bytes to trigger cleanup near 90% usage.
# WENJUAN_DEMO_DB_MAX_BYTES=500000000
