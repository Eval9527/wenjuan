{
  "_notes": [
    "复制本文件为 config/ai-models.local.json，并只在 local 文件里填写真实 apiKey。",
    "这是唯一的 AI 模型配置来源；不要再在 .env.local 里写 AI 模型地址、模型名或 key。",
    "timeoutMs 可设置在根节点、provider 或单个 model 上；越靠近 model 优先级越高。",
    "autoTimeoutMs 只影响 auto 模式单次模型等待时间；singleTimeoutMs 只影响用户手动选择某个模型时的等待时间。"
  ],
  "autoTimeoutMs": 30000,
  "singleTimeoutMs": 60000,
  "providers": [
    {
      "_notes": "一个 OpenAI-compatible 地址可以配置一个或多个模型。",
      "id": "local",
      "alias": "本地服务",
      "api": "openai-completions",
      "apiKey": "<replace-with-your-key>",
      "baseUrl": "http://localhost:4000/v1",
      "headers": {
        "User-Agent": "Wenjuan Demo"
      },
      "models": [
        {
          "id": "mimo-v2.5",
          "alias": "Mimo 主模型",
          "primary": true
        },
        {
          "id": "qwen2.5",
          "alias": "Qwen 备用"
        }
      ]
    },
    {
      "_notes": "第二个 provider 表示另一个地址/服务商，可作为 auto 模式备用。",
      "id": "backup",
      "alias": "备用服务",
      "api": "openai-completions",
      "apiKey": "<replace-with-your-backup-key>",
      "baseUrl": "https://ai.example.test/v1",
      "timeoutMs": 45000,
      "models": [
        {
          "id": "deepseek-chat",
          "alias": "DeepSeek 备用"
        }
      ]
    }
  ]
}
